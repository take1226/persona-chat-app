# Firebase — クライアント（公開可）
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — サーバー専用（秘密）
# Firebase Console → プロジェクト設定 → サービスアカウント → 新しい秘密鍵を生成 → JSONをそのまま1行にして貼る
FIREBASE_SERVICE_ACCOUNT_JSON=

# AI — サーバー専用（秘密）
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=

# Vercel Blob — ファイルストレージ
BLOB_READ_WRITE_TOKEN=

# Web Push 通知
# 生成方法: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# アプリ設定
NEXT_PUBLIC_APP_NAME=ペルソナトーク
APP_PASSWORD=

# Cron認証（GitHub Actions Secrets と Vercel 両方に設定）
CRON_SECRET=
