# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini API（無料）: https://aistudio.google.com/apikey でAPIキーを取得
GEMINI_API_KEY=your_gemini_api_key

# アプリ認証パスワード（プライベート利用）
APP_PASSWORD=your_private_password

# Supabase Storage バケット名
STORAGE_BUCKET_PERSONA_IMAGES=persona-images
STORAGE_BUCKET_UPLOADS=upload-sources

# Web Push VAPID キー
# 生成方法: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your@email.com

# アプリ名（プッシュ通知のタイトルに使用）
NEXT_PUBLIC_APP_NAME=トークアプリ
